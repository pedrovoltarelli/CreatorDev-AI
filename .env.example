# GitHub OAuth App (https://github.com/settings/developers)
# Create a new OAuth App with callback URL: http://localhost:3000/dashboard/github/callback
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Supabase (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# OpenAI API Key (for content generation)
OPENAI_API_KEY=your_openai_api_key_here

# IronPay (https://app.ironpayapp.com.br)
IRONPAY_API_TOKEN=your_ironpay_api_token_here
NEXT_PUBLIC_IRONPAY_API_URL=https://api.ironpayapp.com.br/api/public/v1

# Database (if using Prisma)
DATABASE_URL=your_database_url_here